[Unit]
Description=STEM Studio Django Backend
After=network.target

[Service]
Type=simple
User=__APP_USER__
Group=__APP_GROUP__
WorkingDirectory=__PROJECT_ROOT__/backend
Environment=PYTHONUNBUFFERED=1
Environment=BIND_HOST=127.0.0.1
Environment=PORT=__BACKEND_PORT__
ExecStart=__PROJECT_ROOT__/backend/.venv/bin/gunicorn -c __PROJECT_ROOT__/backend/gunicorn.conf.py config.wsgi:application
Restart=always
RestartSec=3
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target

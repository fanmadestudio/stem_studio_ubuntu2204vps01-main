[Unit]
Description=STEM Studio Django Backend
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
User=__APP_USER__
Group=__APP_GROUP__
WorkingDirectory=__PROJECT_ROOT__/backend
Environment=PYTHONUNBUFFERED=1
ExecStart=__PROJECT_ROOT__/backend/.venv/bin/gunicorn -c __PROJECT_ROOT__/backend/gunicorn.conf.py config.wsgi:application
Restart=always
RestartSec=3
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target

DJANGO_SECRET_KEY=replace-with-strong-secret
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Frontend origins that can call backend API
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
# Optional: use a full PostgreSQL connection string instead of the split vars below.
# Example:
# DATABASE_URL=postgresql://stemstudio:change-me-strong-password@127.0.0.1:5432/stem_studio?sslmode=prefer
# If your password contains special characters like @, encode them first.
# Example: 27Jehoshu@96 becomes 27Jehoshu%4096
# DATABASE_URL=
DB_ENGINE=django.db.backends.postgresql
DB_NAME=stem_studio
DB_USER=stemstudio
DB_PASSWORD=change-me-strong-password
DB_HOST=127.0.0.1
DB_PORT=5432
DB_SSLMODE=prefer
DB_CONNECT_TIMEOUT=10

DJANGO_SECRET_KEY=replace-with-strong-secret
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Frontend origins that can call backend API
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Supabase Auth
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=replace-with-supabase-publishable-key

# Database
# Optional: use a full Supabase/Postgres connection string instead of the split vars below.
# Example for CodeSandbox / IPv4 environments:
# DATABASE_URL=postgresql://postgres.your-project-ref:password@aws-0-your-region.pooler.supabase.com:5432/postgres?sslmode=require
# DATABASE_URL=
DB_ENGINE=django.db.backends.postgresql
DB_NAME=postgres
DB_USER=postgres.your-project-ref
DB_PASSWORD=replace-with-supabase-db-password
DB_HOST=aws-0-your-region.pooler.supabase.com
DB_PORT=5432
DB_SSLMODE=require
DB_CONNECT_TIMEOUT=10

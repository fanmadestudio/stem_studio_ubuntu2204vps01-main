DJANGO_SECRET_KEY=replace-with-strong-secret
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated HTTPS origins for production admin forms, for example:
# DJANGO_CSRF_TRUSTED_ORIGINS=https://stemstudio.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_SECURE_PROXY_SSL_HEADER=0
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_SESSION_COOKIE_SECURE=0
DJANGO_CSRF_COOKIE_SECURE=0

# Database
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_CONN_MAX_AGE=60

# Optional encrypted SQLite backend. Requires sqlcipher3 and SQLCipher system libs.
# DB_ENGINE=config.db.backends.sqlcipher
# SQLCIPHER_KEY=replace-with-strong-sqlcipher-key

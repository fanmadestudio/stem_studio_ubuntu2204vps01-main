DJANGO_SECRET_KEY=replace-with-strong-secret
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Frontend origins that can call backend API
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_CONN_MAX_AGE=60

# Optional encrypted SQLite backend. Requires sqlcipher3 and SQLCipher system libs.
# DB_ENGINE=config.db.backends.sqlcipher
# SQLCIPHER_KEY=replace-with-strong-sqlcipher-key
